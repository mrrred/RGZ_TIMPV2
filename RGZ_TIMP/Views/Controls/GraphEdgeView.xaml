<UserControl x:Class="RGZ_TIMP.Views.Controls.GraphEdgeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MouseLeftButtonDown="OnMouseLeftButtonDown">
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Удалить" Command="{Binding DeleteCommand}"/>
        </ContextMenu>
    </UserControl.ContextMenu>
    <UserControl.ToolTip>
        <StackPanel>
            <TextBlock Text="{Binding LocalOrder, StringFormat='Порядок дуги: {0}'}"/>
            <TextBlock Text="{Binding Predicate, StringFormat='Предикат: {0}'}"/>
            <TextBlock Text="{Binding DelaySeconds, StringFormat='Задержка: {0} сек'}"/>
        </StackPanel>
    </UserControl.ToolTip>
    <Canvas>
        <Path Data="{Binding Geometry}" Stroke="Transparent" StrokeThickness="12" Cursor="Hand"/>
        <Path Data="{Binding Geometry}" Stroke="Black" StrokeThickness="2" IsHitTestVisible="False"/>
        <Polygon Points="{Binding ArrowPoints}" Fill="Black" Cursor="Hand"/>
    </Canvas>
</UserControl>