<Window x:Class="RGZ_TIMP.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RGZ_TIMP.ViewModels"
        xmlns:controls="clr-namespace:RGZ_TIMP.Views.Controls"
        xmlns:srv="clr-namespace:RGZ_TIMP.Services"
        Title="Графопостроитель" Height="700" Width="1100"
        srv:HelpProvider.HelpKeyword="concept.html"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.InputBindings>
        <KeyBinding Command="{Binding UndoCommand}" Key="Z" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding RedoCommand}" Key="Z" Modifiers="Ctrl+Shift" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Меню -->
        <Menu Grid.Row="0">
            <MenuItem Header="Команды">
                <MenuItem Header="Создать" Command="{Binding NewProjectCommand}" srv:HelpProvider.HelpKeyword="cmd_new.html" ToolTip="Создать новый проект"/>
                <MenuItem Header="Открыть" Command="{Binding LoadCommand}" srv:HelpProvider.HelpKeyword="cmd_open.html" ToolTip="Открыть проект из файла"/>
                <MenuItem Header="Сохранить" Command="{Binding SaveCommand}" srv:HelpProvider.HelpKeyword="cmd_save.html" ToolTip="Сохранить текущий проект"/>
            </MenuItem>
            <MenuItem Header="Анимация" Command="{Binding AnimationSettingsCommand}" IsEnabled="{Binding HasProject}" srv:HelpProvider.HelpKeyword="cmd_anim_settings.html" ToolTip="Изменить параметры анимации"/>
            <MenuItem Header="Выполнить" Command="{Binding RunAnimationCommand}" IsEnabled="{Binding HasProject}" srv:HelpProvider.HelpKeyword="cmd_anim_run.html" ToolTip="Запустить выполнение модели"/>
            <MenuItem Header="Остановить" Command="{Binding StopAnimationCommand}" IsEnabled="{Binding HasProject}" srv:HelpProvider.HelpKeyword="cmd_anim_stop.html" ToolTip="Прервать выполнение модели"/>
            <MenuItem Header="?" Command="{Binding ShowHelpCommand}" srv:HelpProvider.HelpKeyword="concept.html" ToolTip="Показать справку по программе"/>
        </Menu>

        <!-- Canvas с узлами и рёбрами -->
        <Canvas Grid.Row="1" Background="WhiteSmoke"
                IsEnabled="{Binding HasProject}"
                MouseRightButtonDown="Canvas_MouseRightButtonDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
            <Canvas.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить" Command="{Binding AddNodeCommand}" srv:HelpProvider.HelpKeyword="cmd_add_node.html" ToolTip="Добавить новый узел"/>
                </ContextMenu>
            </Canvas.ContextMenu>

            <!-- Preview line -->
            <Line x:Name="PreviewLine"
                  X1="{Binding PreviewX1}" Y1="{Binding PreviewY1}"
                  X2="{Binding PreviewX2}" Y2="{Binding PreviewY2}"
                  Stroke="#4A3D3D3D" StrokeThickness="2" StrokeDashArray="3,2">
                <Line.Style>
                    <Style TargetType="Line">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Line.Style>
            </Line>

            <!-- Рёбра -->
            <ItemsControl ItemsSource="{Binding Edges}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:GraphEdgeView/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Узлы -->
            <ItemsControl ItemsSource="{Binding Nodes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:GraphNodeView/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>

        <!-- Строка состояния -->
        <Border Grid.Row="2" Padding="10" Background="#F1F1F1">
            <TextBlock Text="{Binding ModeText}" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>